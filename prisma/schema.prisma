// AVASC — anti-scam platform (Prisma + Supabase Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// App user profile (id matches Supabase auth.users.id)
model User {
  id                     String    @id @db.Uuid
  email                  String?
  role                   UserRole  @default(victim)
  prefersAnonymousSubmit Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  casesReported Case[]    @relation("CaseReporter")
  stories       Story[]
  comments      Comment[]
}

enum UserRole {
  victim
  admin
  moderator
}

enum CaseVisibility {
  private
  anonymized
  public
}

enum CaseStatus {
  draft
  submitted
  under_review
  closed
}

enum IndicatorType {
  phone
  email
  domain
  wallet
  other
}

enum StoryStatus {
  pending
  approved
  rejected
}

enum CommentStatus {
  pending
  approved
  rejected
}

/// Victim-submitted scam report
model Case {
  id                  String         @id @default(cuid())
  reporterUserId      String?        @db.Uuid
  visibility          CaseVisibility @default(private)
  status              CaseStatus     @default(submitted)
  scamType            String
  amountCents         Int?
  currency            String?        @default("USD")
  paymentMethod       String?
  occurredAtStart     DateTime?
  occurredAtEnd       DateTime?
  title               String
  /// Full narrative — never returned on public endpoints
  narrativePrivate    String         @db.Text
  /// Anonymized summary — safe for public when visibility allows
  narrativePublic     String?        @db.Text
  supportRequested    Boolean        @default(false)
  isAnonymousSubmit   Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  reporter   User?            @relation("CaseReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  indicators CaseIndicator[]
  evidence   EvidenceFile[]
  entityLinks CaseEntityLink[]
}

model CaseIndicator {
  id        String         @id @default(cuid())
  caseId    String
  type      IndicatorType
  /// Normalized for search (lowercased / trimmed)
  value     String
  rawValue  String?
  createdAt DateTime       @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([type, value])
}

model EvidenceFile {
  id         String   @id @default(cuid())
  caseId     String
  storageKey String
  bucket     String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

/// Aggregated scam indicator (wallet, phone, domain, …)
model ScamEntity {
  id               String         @id @default(cuid())
  type             IndicatorType
  normalizedValue  String
  riskScore        Int            @default(0)
  reportCount      Int            @default(0)
  lastSeenAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  caseLinks CaseEntityLink[]

  @@unique([type, normalizedValue])
  @@index([normalizedValue])
}

model CaseEntityLink {
  caseId   String
  entityId String

  case   Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  entity ScamEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([caseId, entityId])
}

model Story {
  id            String       @id @default(cuid())
  authorUserId  String?      @db.Uuid
  status        StoryStatus  @default(pending)
  title         String
  body          String       @db.Text
  isAnonymous   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  author   User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  comments Comment[]
}

model Comment {
  id           String        @id @default(cuid())
  storyId      String
  authorUserId String        @db.Uuid
  body         String        @db.Text
  status       CommentStatus @default(pending)
  createdAt    DateTime      @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([storyId])
}
